{
  "name": "@yourname/md-summarizer",
  "version": "1.0.0",
  "description": "Smart markdown documentation summarizer with AI-quality analysis",
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxixo/md-summarizer.git"
  },
  "bugs": {
    "url": "https://github.com/maxixo/md-summarizer/issues"
  },
  "homepage": "https://github.com/maxixo/md-summarizer#readme",
  "keywords": [
    "markdown",
    "documentation",
    "cli",
    "summarizer",
    "docs",
    "analyzer",
    "technical-writing",
    "documentation-generator"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "md-summarizer": "./bin/cli.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prebuild": "npm run clean",
    "clean": "if exist dist rmdir /s /q dist",
    "dev": "ts-node src/index.ts",
    "start": "node ./bin/cli.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "check:deps": "npx npm-check-updates",
    "prepublishOnly": "npm run audit && npm run lint && npm test && npm run build",
    "version": "npm run build && git add -A dist",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "glob": "^10.3.10",
    "marked": "^11.1.1",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/marked": "^6.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.5.0",
    "npm-check-updates": "^17.1.11",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
